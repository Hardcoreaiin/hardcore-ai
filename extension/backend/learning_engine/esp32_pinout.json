    "arduino_function_map": {
        "pinMode": {
            "description": "Sets a GPIO as INPUT or OUTPUT",
            "extracts": [
                "pin_number",
                "mode"
            ],
            "example": "pinMode(2, OUTPUT)"
        },
        "digitalWrite": {
            "description": "Writes HIGH or LOW to a digital GPIO",
            "extracts": [
                "pin_number",
                "value"
            ],
            "example": "digitalWrite(2, HIGH)"
        },
        "digitalRead": {
            "description": "Reads HIGH or LOW from a digital GPIO",
            "extracts": [
                "pin_number"
            ],
            "example": "digitalRead(4)"
        },
        "analogRead": {
            "description": "Reads analog value (0-4095) from an ADC pin",
            "extracts": [
                "pin_number"
            ],
            "example": "analogRead(34)"
        },
        "analogWrite": {
            "description": "Writes PWM value to a pin (ledcWrite preferred on ESP32)",
            "extracts": [
                "pin_number",
                "value"
            ],
            "example": "analogWrite(5, 128)"
        },
        "ledcAttachPin": {
            "description": "Attaches a GPIO to a PWM channel",
            "extracts": [
                "pin_number",
                "channel"
            ],
            "example": "ledcAttachPin(16, 0)"
        },
        "dacWrite": {
            "description": "Writes analog value to DAC pin (GPIO25 or GPIO26 only)",
            "extracts": [
                "pin_number",
                "value"
            ],
            "example": "dacWrite(25, 200)"
        },
        "Wire.begin": {
            "description": "Initializes I2C bus",
            "extracts": [
                "sda_pin",
                "scl_pin"
            ],
            "default_pins": {
                "SDA": 21,
                "SCL": 22
            },
            "example": "Wire.begin() or Wire.begin(SDA, SCL)"
        },
        "SPI.begin": {
            "description": "Initializes SPI bus",
            "extracts": [
                "sck_pin",
                "miso_pin",
                "mosi_pin",
                "ss_pin"
            ],
            "default_pins": {
                "MOSI": 23,
                "MISO": 19,
                "CLK": 18,
                "SS": 5
            },
            "example": "SPI.begin()"
        },
        "Serial.begin": {
            "description": "Initializes UART0 for serial communication",
            "extracts": [
                "baud_rate"
            ],
            "default_pins": {
                "TX": 1,
                "RX": 3
            },
            "example": "Serial.begin(115200)"
        },
        "Serial2.begin": {
            "description": "Initializes UART2 for serial communication",
            "extracts": [
                "baud_rate",
                "config",
                "rx_pin",
                "tx_pin"
            ],
            "default_pins": {
                "TX": 17,
                "RX": 16
            },
            "example": "Serial2.begin(9600, SERIAL_8N1, 16, 17)"
        },
        "touchRead": {
            "description": "Reads capacitive touch value from a touch-capable pin",
            "extracts": [
                "pin_number"
            ],
            "example": "touchRead(4)"
        },
        "servo.attach": {
            "description": "Attaches a servo to a GPIO pin",
            "extracts": [
                "pin_number"
            ],
            "example": "servo.attach(13)"
        }
    }
}