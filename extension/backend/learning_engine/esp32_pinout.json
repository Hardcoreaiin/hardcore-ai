    "protocols": {
        "I2C": {
            "SDA": {
                "gpio": 21,
                "default": true
            },
            "SCL": {
                "gpio": 22,
                "default": true
            },
            "notes": "Can be remapped to any GPIO via Wire.begin(SDA, SCL)"
        },
        "SPI_VSPI": {
            "MOSI": {
                "gpio": 23
            },
            "MISO": {
                "gpio": 19
            },
            "CLK": {
                "gpio": 18
            },
            "SS": {
                "gpio": 5
            },
            "notes": "Default VSPI bus"
        },
        "SPI_HSPI": {
            "MOSI": {
                "gpio": 13
            },
            "MISO": {
                "gpio": 12
            },
            "CLK": {
                "gpio": 14
            },
            "SS": {
                "gpio": 15
            },
            "notes": "Secondary HSPI bus"
        },
        "UART0": {
            "TX": {
                "gpio": 1
            },
            "RX": {
                "gpio": 3
            },
            "notes": "Used for USB Serial / programming"
        },
        "UART1": {
            "TX": {
                "gpio": 10
            },
            "RX": {
                "gpio": 9
            },
            "notes": "Typically remapped — default pins are internal flash"
        },
        "UART2": {
            "TX": {
                "gpio": 17
            },
            "RX": {
                "gpio": 16
            },
            "notes": "Free UART for external devices"
        },
        "DAC": {
            "DAC1": {
                "gpio": 25
            },
            "DAC2": {
                "gpio": 26
            }
        },
        "ADC1": {
            "CH0": {
                "gpio": 36
            },
            "CH3": {
                "gpio": 39
            },
            "CH4": {
                "gpio": 32
            },
            "CH5": {
                "gpio": 33
            },
            "CH6": {
                "gpio": 34
            },
            "CH7": {
                "gpio": 35
            },
            "notes": "ADC1 works with WiFi. ADC2 does NOT work when WiFi is active."
        },
        "ADC2": {
            "CH0": {
                "gpio": 4
            },
            "CH1": {
                "gpio": 0
            },
            "CH2": {
                "gpio": 2
            },
            "CH3": {
                "gpio": 15
            },
            "CH4": {
                "gpio": 13
            },
            "CH5": {
                "gpio": 12
            },
            "CH6": {
                "gpio": 14
            },
            "CH7": {
                "gpio": 27
            },
            "CH8": {
                "gpio": 25
            },
            "CH9": {
                "gpio": 26
            },
            "notes": "ADC2 CANNOT be used when WiFi is active"
        },
        "Touch": {
            "TOUCH0": {
                "gpio": 4
            },
            "TOUCH1": {
                "gpio": 0
            },
            "TOUCH2": {
                "gpio": 2
            },
            "TOUCH3": {
                "gpio": 15
            },
            "TOUCH4": {
                "gpio": 13
            },
            "TOUCH5": {
                "gpio": 12
            },
            "TOUCH6": {
                "gpio": 14
            },
            "TOUCH7": {
                "gpio": 27
            },
            "TOUCH8": {
                "gpio": 33
            },
            "TOUCH9": {
                "gpio": 32
            }
        }
