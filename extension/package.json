{
    "name": "hardcore-ai",
    "displayName": "HARDCOREAI",
    "description": "Cursor for Embedded Systems Engineers - Production Grade Debug & Firmware Platform",
    "version": "0.1.0",
    "publisher": "hardcoreai",
    "icon": "logo.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hardcoreai/hardcore-ai"
    },
    "license": "MIT",
    "categories": [
        "Debuggers",
        "Programming Languages",
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onView:hardcoreai-explorer",
        "onCommand:hardcoreai.startLiveMonitor"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "hardcoreai.analyzeProject",
                "title": "HARDCOREAI: Analyze Current Project",
                "category": "HARDCOREAI"
            },
            {
                "command": "hardcoreai.decodeHardFault",
                "title": "HARDCOREAI: Decode HardFault",
                "category": "HARDCOREAI"
            },
            {
                "command": "hardcoreai.startLiveMonitor",
                "title": "HARDCOREAI: Start Live Hardware Monitor",
                "category": "HARDCOREAI"
            },
            {
                "command": "hardcoreai.analyzeFile",
                "title": "HARDCOREAI: Analyze Specific File",
                "category": "HARDCOREAI"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "hardcoreai-explorer",
                    "title": "HARDCOREAI",
                    "icon": "$(chip)"
                }
            ]
        },
        "views": {
            "hardcoreai-explorer": [
                {
                    "id": "hardcoreai-welcome",
                    "name": "Quick Diagnostics"
                }
            ]
        },
        "configuration": {
            "title": "HARDCOREAI",
            "properties": {
                "hardcoreai.geminiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Google Gemini API Key for AI-backed Hardware Diagnostics.",
                    "scope": "machine-oversridable"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "test-compile": "tsc -p ./",
        "test-watch": "tsc -watch -p ./",
        "pretest": "npm run test-compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "18.x",
        "@typescript-eslint/eslint-plugin": "^6.13.1",
        "@typescript-eslint/parser": "^6.13.1",
        "eslint": "^8.54.0",
        "typescript": "^5.3.2",
        "ts-loader": "^9.5.1",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    }
}
